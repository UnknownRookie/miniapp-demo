.detail-page {
  padding-bottom: 64rpx;
}

.cover {
  width: 100%;
  height: 520rpx;
  display: block;
}

.card {
  margin: -48rpx 24rpx 0;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.user-line {
  font-size: 24rpx;
  color: #64748b;
}

.title {
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #0f172a;
}

.price {
  margin-top: 16rpx;
  font-size: 40rpx;
  color: #dc2626;
  font-weight: 600;
}

.desc {
  margin-top: 24rpx;
  color: #475569;
  line-height: 1.8;
}

.logout-btn {
  margin: 40rpx 24rpx 0;
  border-radius: 999rpx;
  color: #0f172a;
  border-color: #cbd5e1;
}

.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #64748b;
}
